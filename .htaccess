DirectoryIndex index.html
Options -MultiViews
RewriteEngine On
RewriteBase /

# Remove .html from public URLs.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+sas\.html[\s?] [NC]
RewriteRule ^SAS\.html$ /sas [R=301,L,NC]

RewriteCond %{THE_REQUEST} \s/+sia\.html[\s?] [NC]
RewriteRule ^SIA\.html$ /sia [R=301,L,NC]

RewriteCond %{THE_REQUEST} \s/+sis\.html[\s?] [NC]
RewriteRule ^SIS\.html$ /sis [R=301,L,NC]

RewriteCond %{THE_REQUEST} \s/+sse\.html[\s?] [NC]
RewriteRule ^SSE\.html$ /sse [R=301,L,NC]

RewriteCond %{REQUEST_URI} !^/assets/ [NC]
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+?)\.html$ /$1 [R=301,L,NE]

# Keep extensionless page URLs canonical.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ $1 [R=301,L]

# Serve extensionless URLs from their .html files.
RewriteRule ^sas$ SAS.html [L,NC]
RewriteRule ^sia$ SIA.html [L,NC]
RewriteRule ^sis$ SIS.html [L,NC]
RewriteRule ^sse$ SSE.html [L,NC]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
