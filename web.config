<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Pagina inicial do site (garante que "/" sirva o index.html
         mesmo em um IIS com lista de documentos padrao restrita). -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- MIME types que algumas versoes do IIS nao trazem por padrao.
         .webp e um gotcha classico (404 nas imagens). Incluido por
         prevencao, caso essas imagens venham a ser usadas no site.
         O <remove> antes do <mimeMap> evita erro de entrada duplicada
         em IIS mais novos que ja conhecem .webp. -->
    <staticContent>
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>

    <!--
      URLs limpas: reescreve /sistemas para sistemas.html, /contato para
      contato.html, etc. So reescreve quando o arquivo .html correspondente
      existe; arquivos reais (css, js, imagens) e a raiz nao sao afetados.

      >>> REQUER o modulo "URL Rewrite" do IIS instalado no servidor. <<<
      Sem o modulo, o IIS retorna erro 500.19. Nesse caso:
        - instale o URL Rewrite: https://www.iis.net/downloads/microsoft/url-rewrite
        - OU remova este bloco <rewrite> (o site funciona, mas os links
          internos precisariam apontar para .html).
    -->
    <rewrite>
      <rules>
        <rule name="Extensionless HTML" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_FILENAME}.html" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:1}.html" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>
</configuration>
